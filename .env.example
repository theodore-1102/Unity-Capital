# Sutanto Capital — Environment Configuration
# Copy this file to .env and fill in your API credentials.

SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=0

# Bloomberg Data License / B-PIPE
BLOOMBERG_API_KEY=
BLOOMBERG_HOST=localhost
BLOOMBERG_PORT=8194

# Mergermarket (ION Analytics / Acuris)
MERGERMARKET_API_KEY=
MERGERMARKET_BASE_URL=https://api.mergermarket.com/v1

# S&P Capital IQ
SP_CAPITALIQ_API_KEY=
SP_CAPITALIQ_USERNAME=
SP_CAPITALIQ_PASSWORD=
SP_CAPITALIQ_BASE_URL=https://api-ciq.marketintelligence.spglobal.com/gdsapi/rest/v3

# Google Custom Search
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Secondaries Investor (PEI Media)
SECONDARIES_INVESTOR_API_KEY=
SECONDARIES_INVESTOR_BASE_URL=https://api.secondariesinvestor.com/v1

# Database (optional — defaults to SQLite)
DATABASE_URL=sqlite:///sutanto.db
